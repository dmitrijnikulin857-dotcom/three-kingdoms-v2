generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STAFF
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

enum OrderType {
  TAKEAWAY
  DELIVERY
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Category {
  id        String   @id @default(cuid())
  slug      String   @unique
  nameDe    String
  nameEn    String
  icon      String   @default("utensils")
  sortOrder Int      @default(0)
  dishes    Dish[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Dish {
  id            String   @id @default(cuid())
  slug          String   @unique
  nameDe        String
  nameEn        String
  nameZh        String   @default("")
  descriptionDe String   @default("")
  descriptionEn String   @default("")
  price         Float
  imageUrl      String   @default("")
  spiceLevel    Int      @default(0) // 0 = none, 1 = mild, 2 = hot, 3 = fiery
  isBestseller  Boolean  @default(false)
  isVegetarian  Boolean  @default(false)
  isVegan       Boolean  @default(false)
  isAvailable   Boolean  @default(true) // false = Sold Out
  allergens     String[] @default([])
  sortOrder     Int      @default(0)
  categoryId    String
  category      Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([categoryId])
}

model Reservation {
  id        String            @id @default(cuid())
  name      String
  phone     String
  email     String
  date      String // ISO date (YYYY-MM-DD)
  time      String // HH:mm
  guests    Int
  notes     String            @default("")
  status    ReservationStatus @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([date])
  @@index([status])
}

model Order {
  id           String      @id @default(cuid())
  customerName String
  phone        String
  email        String      @default("")
  type         OrderType   @default(TAKEAWAY)
  address      String      @default("")
  items        Json // [{ dishId, name, price, quantity }]
  subtotal     Float       @default(0)
  deliveryFee  Float       @default(0)
  total        Float
  pickupTime   String      @default("")
  notes        String      @default("")
  status       OrderStatus @default(PENDING)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([status])
  @@index([createdAt])
}

model Setting {
  id                  String   @id @default("singleton")
  openingHours        Json // [{ day, open, close, closed }]
  specialDates        Json     @default("[]") // [{ date, label, closed, open, close }]
  reservationsEnabled Boolean  @default(true)
  takeawayEnabled     Boolean  @default(true)
  deliveryEnabled     Boolean  @default(true)
  deliveryFee         Float    @default(3.5)
  minOrderValue       Float    @default(15.0)
  updatedAt           DateTime @updatedAt
}
