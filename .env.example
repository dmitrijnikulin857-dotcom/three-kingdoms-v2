# PostgreSQL connection string (Vercel Postgres / Neon / Supabase compatible).
# If left empty, the site automatically serves built-in fallback menu data.
DATABASE_URL=""

# Secret used to sign admin session JWTs. Change this in production!
AUTH_SECRET="three-kingdoms-super-secret-change-me-in-production-2024"

# Public base URL of the deployment (used for SEO, sitemap, QR codes).
NEXT_PUBLIC_SITE_URL="https://three-kingdoms.vercel.app"

# Default super-admin credentials (created by prisma/seed.ts).
ADMIN_EMAIL="owner@three-kingdoms.de"
ADMIN_PASSWORD="ChangeMe!2024"
